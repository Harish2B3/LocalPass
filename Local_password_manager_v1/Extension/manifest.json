{
  "manifest_version": 3,
  "name": "PassManager - Secure Password Vault",
  "version": "2.0.0",
  "description": "A secure local password manager with end-to-end encryption, auto-detection, and smart autofill.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "alarms",
    "idle",
    "contextMenus",
    "clipboardWrite",
    "notifications",
    "system.network"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3001/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PassManager - Secure Vault"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "crypto.js",
        "secureMessaging.js",
        "contentScript.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "minimum_chrome_version": "88"
}